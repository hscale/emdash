---
import { getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";
import MarketingBlocks from "../../components/MarketingBlocks.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "pricing", { locale: "vi" });

try {
	Astro.cache.set(cacheHint);
} catch {}

const pageContent = page?.data.content;
---

<Base
	title="Bảng giá"
	description="Bảng giá đơn giản, minh bạch. Bắt đầu miễn phí và mở rộng khi doanh nghiệp phát triển."
>
	{
		pageContent ? (
			<MarketingBlocks value={pageContent} />
		) : (
			<div class="empty-state">
				<h1>Bảng giá</h1>
				<p>Thêm nội dung bảng giá trong trang quản trị.</p>
				<a href="/_emdash/admin" class="btn btn-primary">
					Mở trang quản trị
				</a>
			</div>
		)
	}
</Base>

<style>
	.empty-state {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.empty-state h1 {
		margin-bottom: var(--spacing-md);
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: var(--spacing-xl);
	}
</style>
