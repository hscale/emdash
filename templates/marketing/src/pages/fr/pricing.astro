---
import { getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";
import MarketingBlocks from "../../components/MarketingBlocks.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "pricing", { locale: "fr" });

try {
	Astro.cache.set(cacheHint);
} catch {}

const pageContent = page?.data.content;
---

<Base
	title="Tarifs"
	description="Des tarifs simples et transparents. Pas de frais caches. Pas de surprises."
>
	{
		pageContent ? (
			<MarketingBlocks value={pageContent} />
		) : (
			<div class="empty-state">
				<h1>Tarifs</h1>
				<p>Ajoutez le contenu des tarifs dans l'administration.</p>
				<a href="/_emdash/admin" class="btn btn-primary">
					Ouvrir l'administration
				</a>
			</div>
		)
	}
</Base>

<style>
	.empty-state {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.empty-state h1 {
		margin-bottom: var(--spacing-md);
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: var(--spacing-xl);
	}
</style>
