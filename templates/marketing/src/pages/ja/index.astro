---
import { getEmDashEntry, getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import MarketingBlocks from "../../components/MarketingBlocks.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "home", { locale: "ja" });

try {
	Astro.cache.set(cacheHint);
} catch {}

const pageTitle = page?.data.title;
const pageContent = page?.data.content;

let latestPosts: any[] = [];
try {
	const result = await getEmDashCollection("posts", {
		orderBy: "created_at",
		order: "desc",
		limit: 6,
		locale: "ja",
	});
	latestPosts = result.entries || [];
} catch {}
---

<Base
	title={pageTitle !== "ホーム" ? pageTitle : undefined}
	description="人々が本当に求める製品を構築しましょう。現代のチームのためのオールインワンプラットフォーム。"
>
	{
		pageContent ? (
			<MarketingBlocks value={pageContent} />
		) : (
			<div class="empty-state">
				<h1>ようこそ</h1>
				<p>管理画面でホームページのコンテンツを編集して始めましょう。</p>
				<a href="/_emdash/admin" class="btn btn-primary">
					管理画面を開く
				</a>
			</div>
		)
	}

	{latestPosts && latestPosts.length > 0 && (
		<section class="latest-posts">
			<div class="container">
				<h2 class="section-heading">最新のブログ記事</h2>
				<div class="posts-grid">
					{latestPosts.map((post) => (
						<a href={`/ja/posts/${post.id}`} class="post-card">
							<h3 class="post-title">{post.data.title}</h3>
							{post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
							<span class="post-link">続きを読む &rarr;</span>
						</a>
					))}
				</div>
				<div class="posts-cta">
					<a href="/ja/posts" class="btn btn-secondary">すべての記事 &rarr;</a>
				</div>
			</div>
		</section>
	)}
</Base>

<style>
	.empty-state {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.empty-state h1 {
		margin-bottom: var(--spacing-md);
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: var(--spacing-xl);
	}

	.latest-posts {
		padding: var(--spacing-5xl) 0;
		border-top: 1px solid var(--color-border);
	}

	.section-heading {
		text-align: center;
		margin-bottom: var(--spacing-3xl);
		font-size: var(--font-size-3xl);
		font-weight: 700;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-xl);
	}

	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
		padding: var(--spacing-xl);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
	}

	.post-card:hover {
		border-color: var(--color-primary);
		box-shadow: 0 0 24px var(--color-glow), 0 8px 16px rgba(0,0,0,.3);
		transform: translateY(-2px);
	}

	.post-card .post-title {
		font-size: var(--font-size-lg);
		font-weight: 600;
		line-height: 1.4;
	}

	.post-card .post-excerpt {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card .post-link {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-primary);
		margin-top: auto;
		padding-top: var(--spacing-sm);
	}

	.posts-cta {
		text-align: center;
		margin-top: var(--spacing-2xl);
	}

	@media (max-width: 768px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 540px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
