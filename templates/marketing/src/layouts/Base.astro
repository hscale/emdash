---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const settings = await getSiteSettings();
const siteTitle = settings?.title || "ISO BPMS";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription =
	settings?.tagline || "AI-Powered Business Process Management";

const menu = await getMenu("primary");

// Detect current locale
const langMatch = Astro.url.pathname.match(/^\/(vi|ja|ko|fr|zh)/);
const lang = langMatch ? langMatch[1] : "en";
const prefix = lang === "en" ? "" : `/${lang}`;

const i18n: Record<string, Record<string, string>> = {
	en: {
		cta: "Get Started", product: "Product", resources: "Resources", connect: "Connect",
		aiCore: "AI Core", features: "Features", modules: "Modules", pricing: "Pricing",
		blog: "Blog",
		getStarted: "Get Started", login: "Login", contact: "Contact",
		github: "GitHub", email: "Email Us", rights: "All rights reserved.",
		light: "Light", dark: "Dark", system: "System", tagline: "AI-Powered Business Process Management",
	},
	vi: {
		cta: "Bắt đầu", product: "Sản phẩm", resources: "Tài nguyên", connect: "Kết nối",
		aiCore: "AI Core", features: "Tính năng", modules: "Module", pricing: "Bảng giá",
		blog: "Bài viết",
		getStarted: "Bắt đầu", login: "Đăng nhập", contact: "Liên hệ",
		github: "GitHub", email: "Gửi email", rights: "Bản quyền đã được bảo hộ.",
		light: "Sáng", dark: "Tối", system: "Hệ thống", tagline: "Quản lý quy trình doanh nghiệp với AI",
	},
	ja: {
		cta: "始める", product: "製品", resources: "リソース", connect: "つながる",
		aiCore: "AI コア", features: "機能", modules: "モジュール", pricing: "料金",
		blog: "ブログ",
		getStarted: "始める", login: "ログイン", contact: "お問い合わせ",
		github: "GitHub", email: "メール", rights: "全著作権所有。",
		light: "ライト", dark: "ダーク", system: "システム", tagline: "AI搭載ビジネスプロセス管理",
	},
	ko: {
		cta: "시작하기", product: "제품", resources: "리소스", connect: "연결",
		aiCore: "AI 코어", features: "기능", modules: "모듈", pricing: "요금제",
		blog: "블로그",
		getStarted: "시작하기", login: "로그인", contact: "문의",
		github: "GitHub", email: "이메일", rights: "모든 권리 보유.",
		light: "라이트", dark: "다크", system: "시스템", tagline: "AI 기반 비즈니스 프로세스 관리",
	},
	fr: {
		cta: "Commencer", product: "Produit", resources: "Ressources", connect: "Contact",
		aiCore: "AI Core", features: "Fonctionnalités", modules: "Modules", pricing: "Tarifs",
		blog: "Blog",
		getStarted: "Commencer", login: "Connexion", contact: "Contact",
		github: "GitHub", email: "Email", rights: "Tous droits réservés.",
		light: "Clair", dark: "Sombre", system: "Système", tagline: "Gestion des processus métier par IA",
	},
	zh: {
		cta: "开始使用", product: "产品", resources: "资源", connect: "联系",
		aiCore: "AI 核心", features: "功能", modules: "模块", pricing: "价格",
		blog: "博客",
		getStarted: "开始使用", login: "登录", contact: "联系我们",
		github: "GitHub", email: "邮件", rights: "保留所有权利。",
		light: "浅色", dark: "深色", system: "系统", tagline: "AI驱动的业务流程管理",
	},
};
const t = i18n[lang] || i18n.en;

const pageCtx = createPublicPageContext({
	Astro,
	kind: "custom",
	pageType: "website",
	title: fullTitle,
	description: description || siteDescription,
	canonical: Astro.url.href,
	image,
	seo: { ogImage: image },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<EmDashHead page={pageCtx} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://unpkg.com/@phosphor-icons/web@2.1.2/src/regular/style.css"
			rel="stylesheet"
		/>
		<style>
			/* Fallback font with metrics adjusted to match Inter */
			@font-face {
				font-family: "Inter Fallback";
				src: local("Arial");
				size-adjust: 107%;
				ascent-override: 90%;
				descent-override: 25%;
				line-gap-override: 0%;
			}
		</style>
		<script is:inline>
			// Apply theme immediately — default to dark
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "light") {
					document.documentElement.classList.add("light");
				} else {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<nav class="nav">
				<a href={`${prefix}/`} class="site-logo"><img src="/logo.svg" alt={siteTitle} class="site-logo-img" /></a>
				<div class="nav-links">
					<a href={`${prefix}/#ai-core`}>{t.aiCore}</a>
					<a href={`${prefix}/#features`}>{t.features}</a>
					<a href={`${prefix}/#modules`}>{t.modules}</a>
					<a href={`${prefix}/pricing`}>{t.pricing}</a>
					<a href={`${prefix}/posts`}>{t.blog}</a>
					<a href={`${prefix}/contact`}>{t.contact}</a>
				</div>
				<div class="nav-actions">
					<div class="nav-lang-dropdown">
						<button type="button" class="nav-lang-trigger" aria-label="Change language">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
							<span class="nav-lang-current">{
								(() => {
									const m = Astro.url.pathname.match(/^\/(vi|ja|ko|fr|zh)/);
									return m ? m[1].toUpperCase() : "EN";
								})()
							}</span>
						</button>
						<div class="nav-lang-menu">
							{[
								{ code: "en", label: "English", flag: "EN", prefix: "" },
								{ code: "vi", label: "Tiếng Việt", flag: "VI", prefix: "/vi" },
								{ code: "ja", label: "日本語", flag: "JA", prefix: "/ja" },
								{ code: "ko", label: "한국어", flag: "KO", prefix: "/ko" },
								{ code: "fr", label: "Français", flag: "FR", prefix: "/fr" },
								{ code: "zh", label: "中文", flag: "ZH", prefix: "/zh" },
							].map(({ code, label, flag, prefix }) => {
								const path = Astro.url.pathname.replace(/^\/(vi|ja|ko|fr|zh)/, "") || "/";
								const isActive = code === "en"
									? !Astro.url.pathname.match(/^\/(vi|ja|ko|fr|zh)/)
									: Astro.url.pathname.startsWith(`/${code}`);
								return (
									<a href={`${prefix}${path}`} class:list={["lang-option", { active: isActive }]}>
										<span class="lang-flag">{flag}</span>
										<span class="lang-name">{label}</span>
									</a>
								);
							})}
						</div>
					</div>
					<button type="button" class="nav-theme-toggle" aria-label="Toggle theme">
						<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
						<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
					</button>
					<a href="https://app.isobpms.com/signup" class="nav-cta">{t.cta}</a>
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-content">
				<div class="footer-brand">
					<span class="footer-logo"><img src="/logo.svg" alt={siteTitle} class="footer-logo-img" /></span>
					<p class="footer-tagline">{t.tagline}</p>
				</div>
				<div class="footer-links">
					<div class="footer-col">
						<h4>{t.product}</h4>
						<a href={`${prefix}/#ai-core`}>{t.aiCore}</a>
						<a href={`${prefix}/#features`}>{t.features}</a>
						<a href={`${prefix}/#modules`}>{t.modules}</a>
						<a href={`${prefix}/pricing`}>{t.pricing}</a>
						<a href={`${prefix}/posts`}>{t.blog}</a>
					</div>
					<div class="footer-col">
						<h4>{t.resources}</h4>
						<a href="https://app.isobpms.com/signup">{t.getStarted}</a>
						<a href="https://app.isobpms.com">{t.login}</a>
						<a href={`${prefix}/contact`}>{t.contact}</a>
					</div>
					<div class="footer-col">
						<h4>{t.connect}</h4>
						<a href="https://github.com/netadx1ai/isobpms" target="_blank">{t.github}</a>
						<a href="mailto:toi8x@netadx.ai">{t.email}</a>
						<a href="tel:+84965134969">0965 134 969</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p>
					&copy; {new Date().getFullYear()}
					{siteTitle}. {t.rights}
				</p>
				<div class="theme-switcher">
					<button type="button" class="theme-btn" data-theme="light" aria-label={t.light}>{t.light}</button>
					<button type="button" class="theme-btn" data-theme="dark" aria-label={t.dark}>{t.dark}</button>
					<button type="button" class="theme-btn" data-theme="system" aria-label={t.system}>{t.system}</button>
				</div>
				<p class="footer-powered">
					<a href="https://netadx.ai">NetADX AI</a>
				</p>
			</div>
		</footer>

		<script>
			// Theme switcher
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns = document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const headerToggle = document.querySelector<HTMLButtonElement>(".nav-theme-toggle");
			const root = document.documentElement;

			function isDark(): boolean {
				return root.classList.contains("dark") ||
					(!root.classList.contains("light") && window.matchMedia("(prefers-color-scheme: dark)").matches);
			}

			function setTheme(theme: string) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (theme === "system") {
					document.cookie = `theme=; path=/; max-age=0; SameSite=Lax${secure}`;
					root.classList.remove("light", "dark");
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						root.classList.add("dark");
					}
				} else {
					document.cookie = `theme=${theme}; path=/; max-age=31536000; SameSite=Lax${secure}`;
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "dark";
			}

			// Initialize — default to dark
			const storedTheme = getStoredTheme();
			setTheme(storedTheme);

			// Footer buttons
			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					setTheme(btn.dataset.theme || "system");
				});
			});

			// Header toggle: cycles light → dark → light
			headerToggle?.addEventListener("click", () => {
				setTheme(isDark() ? "light" : "dark");
			});

			// Language dropdown
			const langDropdown = document.querySelector<HTMLDivElement>(".nav-lang-dropdown");
			const langTrigger = document.querySelector<HTMLButtonElement>(".nav-lang-trigger");
			langTrigger?.addEventListener("click", (e) => {
				e.stopPropagation();
				langDropdown?.classList.toggle("open");
			});
			document.addEventListener("click", () => {
				langDropdown?.classList.remove("open");
			});

			// Listen for system preference changes
			window.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (e) => {
					if (getStoredTheme() === "system") {
						root.classList.toggle("dark", e.matches);
					}
				});
		</script>

		<style is:global>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			:root {
				/* Dark-first AI high-tech palette */
				--color-bg: #0a0e1a;
				--color-text: #e2e8f0;
				--color-muted: #8892a6;
				--color-border: rgba(123,192,59,.12);
				--color-surface: #111827;
				--color-primary: #7bc03b;
				--color-primary-dark: #5fa82a;
				--color-primary-light: #a3d66e;
				--color-accent: #4f46e5;
				--color-accent-light: #818cf8;
				--color-success: #7bc03b;
				--color-warning: #f59e0b;
				--color-glow: rgba(123,192,59,.15);
				--color-glow-accent: rgba(79,70,229,.15);

				/* Typography */
				--font-sans:
					"Inter", "Inter Fallback", system-ui, -apple-system, sans-serif;
				--font-mono: ui-monospace, "SF Mono", monospace;

				--font-size-xs: 0.75rem;
				--font-size-sm: 0.875rem;
				--font-size-base: 1rem;
				--font-size-lg: 1.125rem;
				--font-size-xl: 1.25rem;
				--font-size-2xl: 1.5rem;
				--font-size-3xl: 2rem;
				--font-size-4xl: 2.5rem;
				--font-size-5xl: 3.5rem;
				--font-size-6xl: 4.5rem;

				/* Spacing */
				--spacing-xs: 0.25rem;
				--spacing-sm: 0.5rem;
				--spacing-md: 1rem;
				--spacing-lg: 1.5rem;
				--spacing-xl: 2rem;
				--spacing-2xl: 3rem;
				--spacing-3xl: 4rem;
				--spacing-4xl: 6rem;
				--spacing-5xl: 8rem;

				/* Layout */
				--max-width: 720px;
				--wide-width: 1200px;
				--radius-sm: 6px;
				--radius: 10px;
				--radius-lg: 16px;
				--radius-full: 9999px;

				/* Transitions */
				--transition-fast: 150ms ease;
				--transition-base: 200ms ease;
				--transition-slow: 300ms ease;

				/* Shadows — glow effects for dark theme */
				--shadow-sm: 0 1px 3px rgba(0,0,0,.4);
				--shadow: 0 4px 12px rgba(0,0,0,.5);
				--shadow-lg: 0 8px 24px rgba(0,0,0,.5), 0 0 20px var(--color-glow);
				--shadow-xl: 0 16px 40px rgba(0,0,0,.5), 0 0 30px var(--color-glow);
			}

			/* Explicit light mode */
			:root.light {
				--color-bg: #ffffff;
				--color-text: #0f172a;
				--color-muted: #64748b;
				--color-border: #e2e8f0;
				--color-surface: #f8fafc;
				--color-primary: #132f5e;
				--color-primary-dark: #0e2347;
				--color-primary-light: #1e4a8a;
				--color-accent: #7bc03b;
				--color-accent-light: #a3d66e;
				--color-glow: rgba(19,47,94,.08);
				--color-glow-accent: rgba(79,70,229,.08);
				--shadow-sm: 0 1px 2px rgba(0,0,0,.05);
				--shadow: 0 4px 6px rgba(0,0,0,.1);
				--shadow-lg: 0 10px 15px rgba(0,0,0,.1);
				--shadow-xl: 0 20px 25px rgba(0,0,0,.1);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: 1.6;
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				min-height: 100vh;
			}

			/* Subtle grid background for high-tech feel */
			body::before {
				content: "";
				position: fixed;
				inset: 0;
				z-index: -1;
				background-image:
					linear-gradient(var(--color-border) 1px, transparent 1px),
					linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
				background-size: 60px 60px;
				opacity: .3;
			}

			a {
				color: currentColor;
				text-decoration: none;
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1,
			h2,
			h3,
			h4,
			h5,
			h6 {
				font-weight: 700;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}

			h1 {
				font-size: var(--font-size-5xl);
			}
			h2 {
				font-size: var(--font-size-3xl);
			}
			h3 {
				font-size: var(--font-size-2xl);
			}
			h4 {
				font-size: var(--font-size-xl);
			}

			/* Utility classes */
			.container {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 var(--spacing-lg);
			}

			.section {
				padding: var(--spacing-5xl) 0;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: var(--spacing-sm);
				padding: var(--spacing-sm) var(--spacing-lg);
				font-family: inherit;
				font-size: var(--font-size-sm);
				font-weight: 600;
				border-radius: var(--radius);
				cursor: pointer;
				transition:
					background var(--transition-fast),
					transform var(--transition-fast),
					box-shadow var(--transition-fast);
			}

			.btn:hover {
				transform: translateY(-1px);
			}

			.btn:active {
				transform: translateY(0);
			}

			.btn-primary {
				color: #0a0e1a;
				background: var(--color-primary);
				border: none;
				box-shadow: 0 0 20px var(--color-glow);
				transition:
					background 0.3s ease,
					box-shadow 0.3s ease;
			}

			.btn-primary:hover {
				background: var(--color-primary-light);
				box-shadow: 0 0 30px var(--color-glow), 0 4px 12px rgba(0,0,0,.3);
			}

			:global(.light) .btn-primary {
				color: white;
			}

			.btn-secondary {
				color: var(--color-text);
				background: transparent;
				border: 1px solid var(--color-border);
			}

			.btn-secondary:hover {
				background: var(--color-surface);
				border-color: var(--color-muted);
			}

			.btn-lg {
				padding: var(--spacing-md) var(--spacing-xl);
				font-size: var(--font-size-base);
			}
		</style>

		<style>
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: rgba(10,14,26,.8);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border-bottom: 1px solid var(--color-border);
			}

			:global(.light) .site-header {
				background: rgba(255,255,255,.85);
			}

			.nav {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-md) var(--spacing-lg);
				display: flex;
				flex-wrap: nowrap;
				align-items: center;
				gap: var(--spacing-lg);
			}

			.site-logo {
				display: flex;
				align-items: center;
			}

			.site-logo-img {
				height: 36px;
				width: auto;
			}

			.nav-links {
				display: flex;
				flex-wrap: wrap;
				gap: var(--spacing-lg);
				margin-left: auto;
			}

			.nav-links a {
				font-size: var(--font-size-sm);
				font-weight: 500;
				color: var(--color-muted);
				transition: color var(--transition-fast);
			}

			.nav-links a:hover {
				color: var(--color-text);
			}

			.nav-actions {
				display: flex;
				align-items: center;
				gap: var(--spacing-lg);
			}

			.nav-lang-dropdown {
				position: relative;
			}

			.nav-lang-trigger {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 6px 10px;
				background: transparent;
				border: 1px solid var(--color-border);
				border-radius: var(--radius-sm);
				color: var(--color-muted);
				font-family: var(--font-sans);
				font-size: var(--font-size-xs);
				font-weight: 600;
				cursor: pointer;
				transition: all var(--transition-fast);
			}

			.nav-lang-trigger:hover {
				color: var(--color-text);
				border-color: var(--color-primary);
			}

			.nav-lang-current {
				letter-spacing: .5px;
			}

			.nav-lang-menu {
				display: none;
				position: absolute;
				top: calc(100% + 8px);
				right: 0;
				min-width: 160px;
				padding: 6px;
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				box-shadow: var(--shadow-lg);
				z-index: 200;
			}

			.nav-lang-dropdown.open .nav-lang-menu {
				display: block;
			}

			.lang-option {
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 8px 12px;
				border-radius: var(--radius-sm);
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				transition: all var(--transition-fast);
			}

			.lang-option:hover {
				background: var(--color-border);
				color: var(--color-text);
			}

			.lang-option.active {
				color: var(--color-primary);
				font-weight: 600;
			}

			.lang-flag {
				font-size: var(--font-size-xs);
				font-weight: 700;
				width: 24px;
				text-align: center;
				opacity: .6;
			}

			.lang-option.active .lang-flag {
				opacity: 1;
			}

			.lang-name {
				flex: 1;
			}

			.nav-theme-toggle {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				background: transparent;
				border: 1px solid var(--color-border);
				border-radius: var(--radius-sm);
				color: var(--color-muted);
				cursor: pointer;
				transition: all var(--transition-fast);
			}

			.nav-theme-toggle:hover {
				color: var(--color-text);
				border-color: var(--color-text);
			}

			/* Show sun in dark mode, moon in light mode */
			.icon-sun { display: none; }
			.icon-moon { display: block; }
			:global(.dark) .icon-sun { display: block; }
			:global(.dark) .icon-moon { display: none; }
			@media (prefers-color-scheme: dark) {
				:global(:root:not(.light)) .icon-sun { display: block; }
				:global(:root:not(.light)) .icon-moon { display: none; }
			}

			.nav-cta {
				padding: var(--spacing-sm) var(--spacing-md);
				font-size: var(--font-size-sm);
				font-weight: 600;
				color: #0a0e1a;
				background: var(--color-primary);
				border-radius: var(--radius-sm);
				box-shadow: 0 0 16px var(--color-glow);
				transition: all 0.3s ease;
			}

			.nav-cta:hover {
				background: var(--color-primary-light);
				box-shadow: 0 0 24px var(--color-glow);
				transform: translateY(-1px);
			}

			:global(.light) .nav-cta {
				color: white;
				background: var(--color-primary);
			}

			main {
				min-height: calc(100vh - 200px);
			}

			.site-footer {
				background: rgba(17,24,39,.6);
				border-top: 1px solid var(--color-border);
				backdrop-filter: blur(8px);
			}

			:global(.light) .site-footer {
				background: var(--color-surface);
				backdrop-filter: none;
			}

			.footer-content {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-4xl) var(--spacing-lg) var(--spacing-2xl);
				display: grid;
				grid-template-columns: 1fr 2fr;
				gap: var(--spacing-4xl);
			}

			.footer-logo {
				display: block;
			}

			.footer-logo-img {
				height: 32px;
				width: auto;
			}

			.footer-tagline {
				margin-top: var(--spacing-sm);
				font-size: var(--font-size-sm);
				color: var(--color-muted);
			}

			.footer-links {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--spacing-xl);
			}

			.footer-col h4 {
				font-size: var(--font-size-sm);
				font-weight: 600;
				margin-bottom: var(--spacing-md);
			}

			.footer-col a {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				padding: var(--spacing-xs) 0;
				transition: color var(--transition-fast);
			}

			.footer-col a:hover {
				color: var(--color-text);
			}

			.footer-bottom {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-lg);
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				border-top: 1px solid var(--color-border);
			}

			.footer-powered a {
				color: var(--color-text);
			}

			.theme-switcher {
				display: flex;
				gap: var(--spacing-xs);
			}

			.theme-btn {
				background: transparent;
				border: 1px solid var(--color-border);
				color: var(--color-muted);
				font-family: var(--font-sans);
				font-size: var(--font-size-sm);
				padding: var(--spacing-xs) var(--spacing-sm);
				border-radius: var(--radius-sm);
				cursor: pointer;
				transition: all var(--transition-fast);
			}

			.theme-btn:hover {
				color: var(--color-text);
				border-color: var(--color-text);
			}

			.theme-btn.active {
				background: var(--color-bg);
				color: var(--color-text);
				border-color: var(--color-primary);
			}

			@media (max-width: 768px) {
				.footer-content {
					grid-template-columns: 1fr;
					gap: var(--spacing-2xl);
				}

				.footer-links {
					grid-template-columns: repeat(2, 1fr);
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-md);
					text-align: center;
				}

				.theme-switcher {
					order: -1;
				}

				h1 {
					font-size: var(--font-size-4xl);
				}
				h2 {
					font-size: var(--font-size-2xl);
				}
			}

			@media (max-width: 540px) {
				.nav {
					flex-wrap: wrap;
					row-gap: var(--spacing-md);
					justify-content: space-between;
				}

				.nav-links {
					order: 3;
					width: 100%;
					justify-content: flex-end;
					margin-left: 0;
				}
			}

			@media (max-width: 480px) {
				.footer-links {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
