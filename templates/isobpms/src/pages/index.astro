---
import { getEmDashEntry, getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import { t } from "../i18n/ui";

const locale = Astro.currentLocale || "en";
const { entry: page, cacheHint } = await getEmDashEntry("pages", "home");
const { entries: aiCaps } = await getEmDashCollection("ai_capabilities", { orderBy: { sort_order: "asc" } });
const { entries: features } = await getEmDashCollection("platform_features", { orderBy: { sort_order: "asc" } });
const { entries: mods } = await getEmDashCollection("modules", { orderBy: { sort_order: "asc" } });
const { entries: testimonials } = await getEmDashCollection("testimonials", { orderBy: { sort_order: "asc" } });
const { entries: allFaq } = await getEmDashCollection("faq_items", { orderBy: { sort_order: "asc" } });
const faqItems = allFaq.filter(e => e.data.page === "home");

try { Astro.cache.set(cacheHint); } catch {}

const p = page?.data;
---

<Base description="AI-Powered Business Process Management. Describe what you need in plain language.">

	<!-- HERO -->
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<h1>{p?.hero_headline || "AI-Powered Processes, Zero Code"}</h1>
				<p class="hero-sub">{p?.hero_subheadline}</p>
				<div class="hero-cta">
					{p?.hero_cta_label && <a href={p.hero_cta_url || "#"} class="btn-primary">{p.hero_cta_label}</a>}
					{p?.hero_secondary_label && <a href={p.hero_secondary_url || "#"} class="btn-ghost">{p.hero_secondary_label}</a>}
				</div>
			</div>
			<div class="hero-visual" aria-hidden="true">
				<div class="hero-graphic">
					<div class="gn gn1"><i class="ph ph-flow-arrow"></i></div>
					<div class="gn gn2"><i class="ph ph-gear"></i></div>
					<div class="gn gn3"><i class="ph ph-check-circle"></i></div>
					<div class="gn gn4"><i class="ph ph-lightning"></i></div>
					<svg class="glines" viewBox="0 0 400 300"><path d="M80 80L200 60L320 80" stroke="var(--color-brand-green)" stroke-width="2" fill="none" opacity=".4"/><path d="M200 60V180" stroke="var(--color-brand-navy)" stroke-width="2" fill="none" opacity=".4"/><path d="M80 180H320" stroke="var(--color-brand-green)" stroke-width="2" fill="none" opacity=".3"/><path d="M80 80V180M320 80V180" stroke="var(--color-brand-navy)" stroke-width="2" fill="none" opacity=".3"/></svg>
				</div>
			</div>
		</div>
	</section>

	<!-- AI CORE -->
	<section class="sec sec-surface" id="ai-core">
		<div class="container">
			<header class="sec-head">
				<h2>{p?.section_headline || "AI is not a feature. It's the foundation."}</h2>
				<p>{p?.section_subheadline}</p>
			</header>
			<div class="grid-3">
				{aiCaps.map(e => (
					<div class="card card-ai">
						<span class="badge-builtin">Built-in</span>
						<div class="card-icon icon-navy"><i class={`ph ph-${e.data.icon || "sparkle"}`}></i></div>
						<h3>{e.data.title}</h3>
						<p>{e.data.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FEATURES -->
	<section class="sec" id="features">
		<div class="container">
			<header class="sec-head">
				<h2>{t(locale, "section.features")}</h2>
				<p>{t(locale, "section.featuresDesc")}</p>
			</header>
			<div class="grid-3">
				{features.map(e => (
					<div class="card">
						<div class="card-icon icon-green"><i class={`ph ph-${e.data.icon || "cube"}`}></i></div>
						<h3>{e.data.title}</h3>
						<p>{e.data.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- MODULES -->
	<section class="sec sec-surface" id="modules">
		<div class="container">
			<header class="sec-head">
				<h2>{t(locale, "section.modules")}</h2>
				<p>{t(locale, "section.modulesDesc")}</p>
			</header>
			<div class="grid-3">
				{mods.map(e => (
					<div class="card card-module">
						<div class="card-icon icon-soft"><i class={`ph ph-${e.data.icon || "package"}`}></i></div>
						<h3>{e.data.name}</h3>
						<p>{e.data.description}</p>
						<div class="module-meta"><span class="module-count">{e.data.object_count} objects</span></div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- TESTIMONIALS -->
	<section class="sec" id="testimonials">
		<div class="container">
			<header class="sec-head"><h2>{t(locale, "section.testimonials")}</h2></header>
			<div class="grid-3">
				{testimonials.map(e => (
					<div class="card card-testimonial">
						<blockquote>"{e.data.quote}"</blockquote>
						<div class="testi-author">
							<div class="testi-avatar">{e.data.initials}</div>
							<div>
								<strong>{e.data.author}</strong>
								<span>{e.data.role}{e.data.role && e.data.company ? " at " : ""}{e.data.company}</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="sec sec-surface">
		<div class="container">
			<header class="sec-head"><h2>{t(locale, "section.faq")}</h2></header>
			<div class="faq-list">
				{faqItems.map(e => (
					<details class="faq-item" name="faq">
						<summary>
							<span>{e.data.question}</span>
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
						</summary>
						<div class="faq-answer"><p>{e.data.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

</Base>

<style>
	/* ── Layout ── */
	.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
	.sec { padding: 4rem 0; }
	.sec-surface { background: var(--color-surface); }
	.sec-head { text-align: center; max-width: 680px; margin: 0 auto 2.5rem; }
	.sec-head h2 { font-size: 2rem; font-weight: 800; margin-bottom: .5rem; }
	.sec-head p { font-size: 1.1rem; color: var(--color-muted); line-height: 1.6; }
	.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

	/* ── Hero ── */
	.hero { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }
	.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center; }
	.hero-text h1 { font-size: 3rem; font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-brand-navy); margin-bottom: 1rem; }
	.hero-sub { font-size: 1.15rem; color: var(--color-muted); line-height: 1.6; margin-bottom: 1.5rem; }
	.hero-cta { display: flex; gap: .75rem; flex-wrap: wrap; }
	.btn-primary { padding: .75rem 1.5rem; font-weight: 600; font-size: .95rem; color: #fff; background: linear-gradient(135deg, var(--color-accent-dark), var(--color-accent)); border-radius: 8px; transition: all .15s; }
	.btn-primary:hover { box-shadow: var(--shadow-lg); transform: translateY(-1px); }
	.btn-ghost { padding: .75rem 1.5rem; font-weight: 600; font-size: .95rem; color: var(--color-text); border: 1px solid var(--color-border); border-radius: 8px; }
	.btn-ghost:hover { background: var(--color-surface); }

	.hero-visual { display: flex; align-items: center; justify-content: center; }
	.hero-graphic { position: relative; width: 360px; height: 260px; }
	.gn { position: absolute; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-size: 1.4rem; box-shadow: var(--shadow-lg); z-index: 1; color: #fff; }
	.gn1 { top: 30px; left: 40px; background: var(--color-brand-navy); }
	.gn2 { top: 15px; right: 40px; background: var(--color-brand-green); }
	.gn3 { bottom: 50px; left: 40px; background: var(--color-indigo); }
	.gn4 { bottom: 50px; right: 40px; background: var(--color-accent-dark); }
	.glines { position: absolute; inset: 0; width: 100%; height: 100%; }

	/* ── Cards ── */
	.card { padding: 1.25rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 12px; transition: transform .2s, box-shadow .2s, border-color .2s; }
	.card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: var(--color-primary-light); }
	.card h3 { font-size: 1rem; font-weight: 700; margin-bottom: .25rem; }
	.card p { font-size: .875rem; color: var(--color-muted); line-height: 1.5; }

	.card-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border-radius: 8px; margin-bottom: .75rem; color: #fff; }
	.icon-navy { background: linear-gradient(135deg, var(--color-brand-navy), var(--color-indigo)); }
	.icon-green { background: linear-gradient(135deg, var(--color-brand-navy), var(--color-brand-green)); }
	.icon-soft { background: rgba(123, 192, 59, 0.12); color: var(--color-brand-navy); font-size: 1.1rem; }

	/* AI Card */
	.card-ai { position: relative; }
	.card-ai:hover { border-color: var(--color-brand-green); }
	.badge-builtin { display: inline-block; padding: 2px 8px; font-size: .7rem; font-weight: 600; color: var(--color-accent-dark); background: rgba(123, 192, 59, 0.12); border-radius: 99px; margin-bottom: .5rem; }

	/* Module Card */
	.card-module { display: flex; flex-direction: column; }
	.card-module:hover { border-color: var(--color-brand-green); }
	.module-meta { margin-top: auto; padding-top: .5rem; border-top: 1px solid var(--color-border); }
	.module-count { font-size: .75rem; font-weight: 600; color: var(--color-brand-green); }

	/* Testimonial Card */
	.card-testimonial { display: flex; flex-direction: column; gap: 1rem; }
	.card-testimonial blockquote { font-size: 1rem; line-height: 1.6; flex: 1; }
	.testi-author { display: flex; align-items: center; gap: .75rem; }
	.testi-avatar { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 700; color: #fff; background: linear-gradient(135deg, var(--color-brand-navy), var(--color-indigo)); border-radius: 50%; flex-shrink: 0; }
	.testi-author strong { display: block; font-size: .875rem; }
	.testi-author span { font-size: .75rem; color: var(--color-muted); }

	/* FAQ */
	.faq-list { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: .5rem; }
	.faq-item { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; }
	.faq-item:hover { border-color: var(--color-muted); }
	.faq-item[open] { border-color: var(--color-brand-green); }
	.faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.25rem; font-weight: 600; font-size: .95rem; cursor: pointer; list-style: none; }
	.faq-item summary::-webkit-details-marker { display: none; }
	.faq-item summary svg { flex-shrink: 0; color: var(--color-muted); transition: transform .2s; }
	.faq-item[open] summary svg { transform: rotate(180deg); }
	.faq-answer { padding: 0 1.25rem 1rem; }
	.faq-answer p { font-size: .875rem; color: var(--color-muted); line-height: 1.7; }

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.grid-3 { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 768px) {
		.hero-inner { grid-template-columns: 1fr; text-align: center; }
		.hero-text h1 { font-size: 2.25rem; }
		.hero-cta { justify-content: center; }
		.hero-visual { order: -1; }
		.hero-graphic { width: 280px; height: 200px; }
		.sec-head h2 { font-size: 1.5rem; }
	}
	@media (max-width: 600px) {
		.grid-3 { grid-template-columns: 1fr; }
	}
</style>
